{
  "name": "card-market-ui",
  "version": "0.0.0",
  "engines": {
    "node": ">=17.0.0 <=22.20.0",
    "npm": ">=9.6.3 <=10.9.2"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve --configuration local",
    "start:external": "npm start -- --host 0.0.0.0 --configuration external",
    "format": "prettier --config ./.prettierrc  \"src\"",
    "format:fix": "npm run format -- --write",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "test": "ng test --code-coverage",
    "test:watch": "npm run test -- --watch",
    "test:sourcemaps": "npm run test -- --code-coverage --source-map=true",
    "test:sourcemaps:watch": "npm run test:sourcemaps -- --watch",
    "test:headless": "ng test --watch=false --code-coverage --source-map=true --browsers=ChromeHeadlessNoSandbox",
    "package:refresh": "rm package-lock.json && npm i",
    "build:production": "ng build --configuration production",
    "heroku-prebuild": "node heroku-pre-build.js",
    "heroku-postbuild": "ng build --aot --configuration=production",
    "pipeline:format": "npm run format -- --check",
    "pipeline:lint": "npm run lint",
    "pipeline:test": "npm run test:headless"
  },
  "dependencies": {
    "@angular/animations": "^20.3.9",
    "@angular/cdk": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/common": "^21.2.9",
    "@angular/compiler": "^21.2.9",
    "@angular/compiler-cli": "^21.2.9",
    "@angular/core": "^21.2.9",
    "@angular/forms": "^21.2.9",
    "@angular/material": "^21.2.7",
    "@angular/platform-browser": "^21.2.9",
    "@angular/platform-browser-dynamic": "^21.2.9",
    "@angular/pwa": "^21.2.7",
    "@angular/router": "^21.2.9",
    "@angular/service-worker": "^21.2.9",
    "@auth0/auth0-angular": "^2.8.0",
    "@stomp/rx-stomp": "2.3.0",
    "@swimlane/ngx-charts": "^23.1.0",
    "bootstrap": "^5.3.3",
    "compression": "^1.8.1",
    "core-js": "^3.45.1",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "express": "^4.17.1",
    "file-saver": "^2.0.5",
    "lodash-es": "^4.17.21",
    "ng2-file-upload": "9.0.0",
    "ngx-colors": "^3.6.0",
    "ngx-skeleton-loader": "^12.0.0",
    "ngx-stripe": "^21.8.0",
    "ngx-toastr": "^19.1.0",
    "pdfmake": "^0.2.20",
    "postcss": "^8.5.3",
    "rxjs": "~7.8.2",
    "tslib": "^2.0.0",
    "zone.js": "0.15.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "21.3.1",
    "@angular-eslint/eslint-plugin": "21.3.1",
    "@angular-eslint/eslint-plugin-template": "21.3.1",
    "@angular-eslint/schematics": "21.3.1",
    "@angular-eslint/template-parser": "21.3.1",
    "@angular/build": "^21.2.7",
    "@angular/language-service": "^21.2.9",
    "@types/bootstrap": "^4.5.0",
    "@types/file-saver": "^2.0.5",
    "@types/jasmine": "~3.8.0",
    "@types/jquery": "^3.3.38",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^12.11.1",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "@typescript-eslint/utils": "^8.46.0",
    "angular-cli-ghpages": "^3.0.3",
    "eslint": "^9.37.0",
    "jasmine-core": "~5.12.0",
    "jasmine-spec-reporter": "~7.0.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "prettier": "^3.4.2",
    "ts-node": "~7.0.0",
    "typescript": "5.9.3"
  }
}
